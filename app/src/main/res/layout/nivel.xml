<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/layoutFila"
            android:layout_width="280dp"
            android:layout_marginEnd="8dp"
            android:layout_height="80dp"

            android:background="@drawable/estilo_botones_bloqueados"
            android:clipToOutline="true"
            android:elevation="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:outlineProvider="background"
            android:padding="8dp">

            <ImageView
                android:id="@+id/imgIcono"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="Icono nivel"
                android:src="@drawable/cerrado" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtNivel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nivel_X"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDescripcion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OPERACIONESCOMBINADAS CON PARENTESIS"
                    android:textColor="#666666"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/buttonJugar"
            android:layout_width="70dp"
            android:layout_height="60dp"
            android:text="@string/play" />


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>